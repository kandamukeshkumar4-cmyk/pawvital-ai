{
  "job_id": "vet-915-narrow-model-pack",
  "purpose": "Coordinate narrow-model experiments that improve extraction and reranking without owning triage",
  "recommended_gpu": "NVIDIA RTX 4090",
  "config": {
    "experiment_pack_id": "vet-915-narrow-model-pack",
    "version": "2026-04-10",
    "species": "dog",
    "experiments": [
      {
        "id": "owner-language-normalization",
        "task": "normalize-owner-language",
        "recommended_gpu": "NVIDIA RTX 4090",
        "dataset_contract": "Owner phrasing -> canonical symptom/sign/qualifier labels",
        "primary_metric": "exact_match",
        "acceptance_threshold": 0.9,
        "rollback_rule": "Do not promote if emergency or red-flag phrasing recall regresses."
      },
      {
        "id": "symptom-entity-extraction",
        "task": "extract-symptom-entities",
        "recommended_gpu": "NVIDIA RTX 4090",
        "dataset_contract": "Free text -> structured symptom and modifier entities",
        "primary_metric": "macro_f1",
        "acceptance_threshold": 0.88,
        "rollback_rule": "Do not promote if protected control-state fields need model output."
      },
      {
        "id": "retrieval-reranking",
        "task": "rerank-retrieval-evidence",
        "recommended_gpu": "NVIDIA RTX 4090",
        "dataset_contract": "Query + candidates -> relevance ranking",
        "primary_metric": "ndcg_at_10",
        "acceptance_threshold": 0.85,
        "rollback_rule": "Do not promote if deterministic emergency logic changes behavior."
      },
      {
        "id": "urgency-cue-classification",
        "task": "classify-urgency-cues",
        "recommended_gpu": "NVIDIA RTX 4090",
        "dataset_contract": "Owner message -> urgency cues only",
        "primary_metric": "emergency_recall",
        "acceptance_threshold": 0.97,
        "rollback_rule": "Do not promote if false reassurance increases."
      }
    ]
  },
  "env_required": [
    "RUNPOD_API_KEY"
  ],
  "inputs": [
    "data/runpod-experiments/narrow-model-pack.json"
  ],
  "outputs": [
    "experiment-metrics.json",
    "model-eval-summary.md"
  ]
}
