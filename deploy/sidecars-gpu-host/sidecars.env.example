# Public routing for the sidecar reverse proxy
SIDECAR_BASE_DOMAIN=sidecars.example.com
ACME_EMAIL=ops@example.com
SIDECAR_API_KEY=replace-with-shared-bearer-token

# Toggle stub vs model-backed behavior per service.
# vision-preprocess, text-retrieval, image-retrieval are CPU-only - safe to run live.
# multimodal-consult and async-review default to stub until a GPU host is confirmed.
VISION_PREPROCESS_STUB_MODE=false
TEXT_RETRIEVAL_STUB_MODE=false
IMAGE_RETRIEVAL_STUB_MODE=false
MULTIMODAL_CONSULT_STUB_MODE=true
ASYNC_REVIEW_STUB_MODE=true

# Retrieval sidecar data access
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-side-key
SUPABASE_TIMEOUT_SECONDS=8

# Text retrieval model settings
TEXT_MODEL_ENABLED=true
TEXT_EMBED_MODEL_NAME=BAAI/bge-m3
TEXT_RERANK_MODEL_NAME=BAAI/bge-reranker-v2-m3
TEXT_MODEL_MAX_CANDIDATES=24

# Image retrieval model settings
IMAGE_MODEL_ENABLED=true
IMAGE_RETRIEVAL_MODEL_NAME=microsoft/BiomedCLIP-PubMedBERT_256-vit_base_patch16_224
IMAGE_MODEL_MAX_ASSETS=12
IMAGE_FETCH_TIMEOUT_SECONDS=6

# Async review settings
MAX_CALLBACK_RETRIES=3
CALLBACK_RETRY_DELAY_SECONDS=5
MAX_SHADOW_HISTORY=1000

# VL model settings (multimodal-consult + async-review).
# Uncomment and set these when running on a GPU host with the corresponding STUB_MODE=false.
# HF_HOME=/model-cache                                       # maps to the model_cache_* Docker volume
# CONSULT_MODEL_ID=Qwen/Qwen2.5-VL-7B-Instruct              # requires >=16 GB VRAM (T4/A10G)
# REVIEW_MODEL_ID=Qwen/Qwen2.5-VL-32B-Instruct              # requires >=80 GB VRAM (A100-80G / H100)
# SKIP_MODEL_DOWNLOAD=false                                 # set true if volume is pre-populated
