# App-side Hugging Face sidecar configuration
# Use full endpoint URLs, not bare hostnames.

HF_VISION_PREPROCESS_URL=http://localhost:8080/infer
HF_TEXT_RETRIEVAL_URL=http://localhost:8081/search
HF_IMAGE_RETRIEVAL_URL=http://localhost:8082/search
HF_MULTIMODAL_CONSULT_URL=http://localhost:8083/consult
HF_ASYNC_REVIEW_URL=http://localhost:8084/review

# Legacy fallback if you temporarily run a combined retrieval service.
HF_RETRIEVAL_SERVICE_URL=

HF_SIDECAR_API_KEY=replace-me
ASYNC_REVIEW_WEBHOOK_SECRET=replace-me

HF_VISION_PREPROCESS_TIMEOUT_MS=8000
HF_TEXT_RETRIEVAL_TIMEOUT_MS=5000
HF_IMAGE_RETRIEVAL_TIMEOUT_MS=5000
HF_MULTIMODAL_CONSULT_TIMEOUT_MS=10000
HF_ASYNC_REVIEW_TIMEOUT_MS=15000

# Optional shadow-mode controls. When enabled, sidecars still run and get logged
# but the app keeps using the NVIDIA/local fallback path for live decisions.
HF_SIDECAR_SHADOW_MODE=false
HF_SHADOW_VISION_PREPROCESS=false
HF_SHADOW_TEXT_RETRIEVAL=false
HF_SHADOW_IMAGE_RETRIEVAL=false
HF_SHADOW_MULTIMODAL_CONSULT=false
HF_SHADOW_ASYNC_REVIEW=false
