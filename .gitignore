# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
__pycache__/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Corpus data (indexed in Supabase, not needed at runtime)
/corpus/

# Scripts (build-time only)
/scripts/*
!/scripts/update-pawvital-memory.mjs
!/scripts/land-pawvital-ticket.mjs
!/scripts/finalize-pawvital-ticket.mjs
!/scripts/agent-done.mjs
!/scripts/apply-outcomes-schema.mjs
!/scripts/build-breed-profiles.mjs
!/scripts/codex-review-result.schema.json
!/scripts/hooks/
!/scripts/hooks/*.mjs
!/scripts/build.js
!/scripts/fix-readlink.js
!/scripts/runpod-benchmark.mjs
!/scripts/generate-benchmark-adjudication-pack.mjs
!/scripts/runpod-hero-job-manifests.mjs
!/scripts/runpod-provision-narrow.mjs
!/scripts/eval-harness.ts
!/scripts/generate-benchmark-cases.ts
!/scripts/validate-benchmark.ts
!/scripts/silent-trial.ts
!/scripts/pipeline-smoke-test.mjs
!/scripts/enrich-benchmark-cases.mjs
!/scripts/stamp-gold-benchmark.mjs
!/scripts/benchmark-quota-tracker.mjs
!/scripts/benchmark-lint.mjs
!/scripts/build-owner-corpus.mjs
!/scripts/eval-narrow-helper.mjs
!/scripts/build-failure-review-queue.mjs
!/scripts/generate-failure-dashboard.mjs
!/scripts/miss-to-ticket.mjs
!/scripts/eval-multimodal-shadow.mjs
!/scripts/multimodal-improvement-report.mjs
!/scripts/multimodal-triage-pilot.mjs
!/scripts/check-emergency-sentinels.mjs

# Generated benchmark/deployment run reports
/data/benchmark/scorecard-*.json
/data/benchmark/shadow-*.json
/runpod-benchmark-report.json
/runpod-benchmark-gold-report.json

# IDE / editor
Roo-Code
.runpod_ssh
