# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Corpus data (indexed in Supabase, not needed at runtime)
/corpus/

# Scripts (build-time only)
/scripts/*
!/scripts/update-pawvital-memory.mjs
!/scripts/land-pawvital-ticket.mjs
!/scripts/finalize-pawvital-ticket.mjs
!/scripts/agent-done.mjs
!/scripts/apply-outcomes-schema.mjs
!/scripts/codex-review-result.schema.json
!/scripts/hooks/
!/scripts/hooks/*.mjs

# IDE / editor
Roo-Code
.runpod_ssh
