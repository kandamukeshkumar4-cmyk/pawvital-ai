# GPU build — CUDA 12.4.
# MINIMUM GPU requirement: 80 GB VRAM for Qwen2.5-VL-32B-Instruct in fp16 (single GPU).
#   - NVIDIA A100-80G or H100-80G: full fp16, ~8–20 s/request
#   - 2× A100-40G / 2× A10G / 4× T4 via pipeline parallel: requires code changes
#   - For 4-bit quantization (bitsandbytes), a single A100-40G is sufficient but slower
#
# Build:  docker build -f Dockerfile.gpu -t async-review-service:gpu .
# Run:    docker run --gpus all -e SIDECAR_API_KEY=... -v /data/model-cache:/model-cache ...
FROM nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        python3.11 \
        python3.11-dev \
        python3-pip \
        build-essential \
        curl \
        git \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/pip    pip    /usr/bin/pip3       1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir \
    "torch==2.5.1" \
    "torchvision==0.20.1" \
    --index-url https://download.pytorch.org/whl/cu124

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app
COPY startup_check.py .
COPY download_models.py .

ENV HF_HOME=/model-cache
ENV MODEL_CACHE_DIR=/model-cache

EXPOSE 8084

HEALTHCHECK --interval=30s --timeout=15s --start-period=3600s --retries=5 \
    CMD curl -f http://localhost:8084/healthz || exit 1

CMD ["sh", "-c", "python startup_check.py && python download_models.py && uvicorn app.main:app --host 0.0.0.0 --port 8084 --log-level info"]
