{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PawVital Dog Triage Benchmark Suite",
  "type": "object",
  "required": ["suite_id", "species", "cases"],
  "additionalProperties": false,
  "properties": {
    "suite_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string" },
    "species": { "const": "dog" },
    "description": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "pet": {
      "type": "object",
      "required": ["name", "breed", "age_years", "weight", "species"],
      "additionalProperties": true,
      "properties": {
        "name": { "type": "string" },
        "breed": { "type": "string" },
        "age_years": { "type": "number", "minimum": 0 },
        "weight": { "type": "number", "minimum": 0 },
        "species": { "const": "dog" }
      }
    },
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "additionalProperties": false,
      "properties": {
        "role": { "enum": ["user", "assistant"] },
        "content": { "type": "string", "minLength": 1 }
      }
    },
    "request": {
      "type": "object",
      "required": ["action", "pet", "messages"],
      "additionalProperties": true,
      "properties": {
        "action": { "enum": ["chat", "generate_report"] },
        "pet": { "$ref": "#/$defs/pet" },
        "session": { "type": "object" },
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/message" }
        },
        "image": { "type": "string" },
        "imageMeta": { "type": "object" }
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "responseType": {
          "enum": ["question", "ready", "emergency", "report", "error", "image_gate"]
        },
        "readyForReport": { "type": "boolean" },
        "conversationState": { "type": "string" },
        "lastQuestionAsked": { "type": "string" },
        "answeredQuestionsInclude": {
          "type": "array",
          "items": { "type": "string" }
        },
        "answeredQuestionsExclude": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knownSymptomsInclude": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knownSymptomsExclude": {
          "type": "array",
          "items": { "type": "string" }
        },
        "extractedAnswersMatch": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        },
        "redFlagsInclude": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reportRecommendation": { "type": "string" },
        "reportSeverity": { "type": "string" },
        "messageIncludes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "case": {
      "type": "object",
      "required": ["id", "description", "request", "expectations"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "complaint_family_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "weight": { "type": "number", "minimum": 0 },
        "risk_tier": { "type": "string", "minLength": 1 },
        "uncertainty_pattern": { "type": "string", "minLength": 1 },
        "must_not_miss_marker": { "type": "boolean" },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_shard": { "type": "string", "minLength": 1 },
            "source_suite_id": { "type": "string", "minLength": 1 },
            "freeze_date": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 }
          }
        },
        "wave3_strata": {
          "type": "array",
          "items": {
            "enum": [
              "emergency",
              "urgent",
              "common",
              "ambiguous",
              "contradictory",
              "low-information",
              "rare-but-critical"
            ]
          }
        },
        "wave3_adjudication": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "high_risk": { "type": "boolean" },
            "review_tier": { "type": "string", "minLength": 1 },
            "reviewer_slots": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["role", "reviewer_id", "status"],
                "properties": {
                  "role": { "type": "string", "minLength": 1 },
                  "reviewer_id": { "type": "string", "minLength": 1 },
                  "status": { "type": "string", "minLength": 1 }
                }
              }
            },
            "disagreement_status": { "type": "string", "minLength": 1 },
            "must_ask_expectations": {
              "type": "object",
              "additionalProperties": false,
              "required": ["question_ids", "status", "notes"],
              "properties": {
                "question_ids": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "status": { "type": "string", "minLength": 1 },
                "notes": { "type": "string" }
              }
            }
          }
        },
        "request": { "$ref": "#/$defs/request" },
        "expectations": { "$ref": "#/$defs/expectations" }
      }
    }
  }
}
