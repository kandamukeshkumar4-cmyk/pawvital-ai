# PawVital local direnv template.
# Copy this file to .envrc on your machine only. Never commit .envrc.
# Keep real secrets in an approved secret manager. If a manager materializes
# an .env file locally, that file must stay ignored and uncommitted.

PATH_add node_modules/.bin

# Approved secret source patterns. Pick one and keep real values outside git.
#
# 1Password CLI via op run. Store only op:// references in the user-level file.
# eval "$(op run --env-file "$HOME/.config/pawvital/secrets/pawvital.1password.env" -- direnv dump bash)"
#
# Doppler. Load directly from the project/config into the local shell.
# dotenv <(doppler secrets download --no-file --format env --project pawvital-ai --config dev)
#
# Infisical. Use the local CLI profile for auth; do not commit exported files.
# dotenv <(infisical export --format=dotenv --projectId "$INFISICAL_PROJECT_ID" --env=dev)
#
# Vault. Fetch only the fields needed for the local command.
# export HF_SIDECAR_API_KEY="$(vault kv get -field=HF_SIDECAR_API_KEY secret/pawvital/dev)"
# export ASYNC_REVIEW_WEBHOOK_SECRET="$(vault kv get -field=ASYNC_REVIEW_WEBHOOK_SECRET secret/pawvital/dev)"
#
# Local fallback for ignored files generated by a secrets manager.
# if [ -f .env.local ]; then
#   source_env .env.local
# fi
#
# Required validation before committing env or ops docs:
# npm run security:secrets
# git diff --check
