# PawVital AI — environment template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local. Keep all secrets out of source control.
# Use your deployment platform's secret manager for production.

# ─── NVIDIA NIM (core LLM — required for live AI features) ───────────────────
# One key covers all model roles. Per-role overrides are optional.
NVIDIA_API_KEY=your_nvidia_nim_key_here
NVIDIA_QWEN_API_KEY=
NVIDIA_KIMI_API_KEY=
NVIDIA_DEEPSEEK_API_KEY=
NVIDIA_GLM_API_KEY=
NVIDIA_VISION_API_KEY=

# ─── Anthropic Claude (second-opinion / fallback LLM) ────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Supabase (database + auth — required for real user data) ─────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
DATABASE_URL=your_supabase_postgres_connection_string_here

# ─── Stripe (payments — required for paid tiers) ─────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ─── Upstash Redis (rate limiting — required in production) ──────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Pinecone (vector search — required for RAG data pipeline) ───────────────
PINECONE_API_KEY=

# ─── Cloudinary (pet photo CDN — required for journal uploads) ───────────────
CLOUDINARY_URL=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── HuggingFace (sidecars + free wound classifier) ──────────────────────────
HF_TOKEN=
HF_SIDECAR_API_KEY=
HF_VISION_PREPROCESS_URL=http://localhost:8080/infer
HF_TEXT_RETRIEVAL_URL=http://localhost:8081/search
HF_IMAGE_RETRIEVAL_URL=http://localhost:8082/search
HF_MULTIMODAL_CONSULT_URL=http://localhost:8083/consult
HF_ASYNC_REVIEW_URL=http://localhost:8084/review
ASYNC_REVIEW_WEBHOOK_SECRET=

# ─── MiniMax (long-session memory compression) ───────────────────────────────
MINIMAX_API_KEY=
MINIMAX_CODING_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MEMORY_MODEL=MiniMax-M2.5

# ─── RunPod (heavy GPU workloads — optional) ─────────────────────────────────
RUNPOD_API_KEY=

# ─── Computer vision classifiers (optional) ──────────────────────────────────
NYCKEL_CLIENT_ID=
NYCKEL_CLIENT_SECRET=
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE_NAME=
ROBOFLOW_WORKFLOW_ID=
API_NINJAS_KEY=

# ─── Model rollout flags (server-side) ───────────────────────────────────────
MODEL_ROUTER_VERSION=v1
SECOND_OPINION_EXTRACTOR=shadow
GROK_FINAL_SAFETY=off
GROK_FINAL_REPORT=off

# ─── xAI Grok (disabled by default — do not enable without explicit sign-off) ─
XAI_API_KEY=
GROK_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_GROK_FINAL_SAFETY_MODEL=grok-4.3
XAI_GROK_FINAL_REPORT_MODEL=grok-4.3

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.example.com
APP_BASE_URL=https://your-app.example.com
