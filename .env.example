# Core app runtime configuration
# Copy this file to .env.local and fill in real values.

# NVIDIA NIM shared key for all models
NVIDIA_API_KEY=nvapi-REPLACE_WITH_YOUR_REAL_NVIDIA_NIM_KEY

# Optional per-role overrides
NVIDIA_QWEN_API_KEY=nvapi-REPLACE_WITH_YOUR_REAL_NVIDIA_NIM_KEY
NVIDIA_KIMI_API_KEY=nvapi-REPLACE_WITH_YOUR_REAL_NVIDIA_NIM_KEY
NVIDIA_DEEPSEEK_API_KEY=nvapi-REPLACE_WITH_YOUR_REAL_NVIDIA_NIM_KEY
NVIDIA_GLM_API_KEY=nvapi-REPLACE_WITH_YOUR_REAL_NVIDIA_NIM_KEY

# Optional local sidecar endpoints for image preprocessing and retrieval flows.
# See .env.sidecars.example for the full sidecar-only template.
HF_VISION_PREPROCESS_URL=http://localhost:8080/infer
HF_TEXT_RETRIEVAL_URL=http://localhost:8081/search
HF_IMAGE_RETRIEVAL_URL=http://localhost:8082/search
HF_MULTIMODAL_CONSULT_URL=http://localhost:8083/consult
HF_ASYNC_REVIEW_URL=http://localhost:8084/review

# Supabase (required for data pipeline)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
NEXT_PUBLIC_APP_URL=https://your-production-app-url.example.com

# Stripe (required for paid subscriptions in production)
STRIPE_SECRET_KEY=sk_live_or_sk_test_replace_me
STRIPE_PRICE_ID=price_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Rate limiting
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
SYMPTOM_CHAT_SESSION_SECRET=replace_with_a_long_random_secret

# Email
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=PawVital <alerts@example.com>

# Admin access
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Database (required for image/audio indexing scripts)
DATABASE_URL=your_database_url_here
